# Target Config
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
# CONFIG_HAS_TESTING_KERNEL=y
# CONFIG_TESTING_KERNEL=y
CONFIG_LINUX_6_18=y
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe"
CONFIG_DEFAULT_amd64-microcode=y
CONFIG_DEFAULT_autocore-x86=y
CONFIG_GCC_USE_VERSION_15=y
# CONFIG_GCC_VERSION="15.0.0"
CONFIG_GCC_VERSION_15=y

# Set Firmware Size
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=500

# Feed
CONFIG_FEED_passwall_packages=y
CONFIG_FEED_passwall=y
# CONFIG_FEED_passwall2=y
#  CONFIG_FEED_helloworld=y
# CONFIG_FEED_OpenClash=y
CONFIG_FEED_packages=y
CONFIG_FEED_luci=y
CONFIG_FEED_routing=y
CONFIG_FEED_telephony=y

# Luci
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-lib-nixio=y
# CONFIG_PACKAGE_luci-nginx=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_busybox=y
# CONFIG_LUCI_CSSTIDY is not set
# CONFIG_LUCI_JSMIN is not set

# Firmware Type
# CONFIG_GRUB_CONSOLE is not set
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_GRUB_CONSOLE=y
CONFIG_GRUB_BAUDRATE=115200
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_TARGZ=y
CONFIG_TARGET_ROOTFS_COMPRESSION_GZIP=y
# CONFIG_VMDK_IMAGES is not set
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_JSON_OVERVIEW_IMAGE_INFO=y
CONFIG_SIGNED_PACKAGES=y
CONFIG_SIGNATURE_CHECK=y
CONFIG_DOWNLOAD_CHECK_CERTIFICATE=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_BUSYBOX_DEFAULT_GZIP=y
CONFIG_BUSYBOX_DEFAULT_GZIP_FAST=0
CONFIG_BUSYBOX_DEFAULT_FEATURE_GZIP_DECOMPRESS=y

# Image Builder
CONFIG_IB=y
CONFIG_IB_STANDALONE=y
CONFIG_DEVEL=y

